{
  "info": {
    "name": "Adullam Backend",
    "_postman_id": "adullam-backend-collection",
    "description": "Multi-tenant backend API.\n\n**Setup:**\n1. Run **Auth / Login** — it auto-sets `token` and `refreshToken`.\n2. All API requests use `{{token}}` and `x-tenant-slug: {{tenantSlug}}`.\n3. If `token` expires, run **Auth / Refresh** to rotate both tokens.\n\nCreate/list requests auto-capture IDs into `categoryId`, `productId`, `discountId`, `promoCodeId` via test scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenantSlug",
      "value": "demo",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string"
    },
    {
      "key": "discountId",
      "value": "",
      "type": "string"
    },
    {
      "key": "promoCodeId",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('token', json.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "    console.log('token and refreshToken set successfully');",
                  "} else {",
                  "    console.error('Login failed', json);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-slug",
                "value": "{{tenantSlug}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Exchange email + password for tokens. Auto-sets `token` and `refreshToken` collection variables. Response: `{ accessToken, refreshToken, user: { id, email } }`."
          }
        },
        {
          "name": "Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('token', json.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "    console.log('Tokens rotated successfully');",
                  "} else {",
                  "    console.error('Refresh failed', json);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-slug",
                "value": "{{tenantSlug}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "refresh"
              ]
            },
            "description": "Rotate both tokens using the stored `refreshToken`. Auto-sets `token` and `refreshToken`. Response: `{ accessToken, refreshToken }`."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "x-tenant-slug",
                "value": "{{tenantSlug}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "logout"
              ]
            },
            "description": "Invalidates all sessions for the authenticated user via Supabase admin API. Requires `Authorization: Bearer {{token}}`. Response: `{ message: \"Logged out\" }`."
          }
        }
      ]
    },
