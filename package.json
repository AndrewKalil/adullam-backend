{
  "name": "adullam-backend",
  "version": "1.0.0",
  "description": "Backend system for retail and restaurants",
  "license": "MIT",
  "author": "Andrew Kalil",
  "type": "commonjs",
  "main": "index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "drizzle-kit": "^0.31.10",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
