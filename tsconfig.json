{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "dist",
    "types": ["node"],
    "paths": {
      "~config": ["./src/config"],
      "~config/*": ["./src/config/*"],
      "~db": ["./src/db"],
      "~db/*": ["./src/db/*"],
      "~middleware": ["./src/middleware"],
      "~middleware/*": ["./src/middleware/*"],
      "~modules": ["./src/modules"],
      "~modules/*": ["./src/modules/*"],
      "~integrations": ["./src/integrations"],
      "~integrations/*": ["./src/integrations/*"],
      "~types": ["./src/types"],
      "~types/*": ["./src/types/*"],
      "~utils": ["./src/utils"],
      "~utils/*": ["./src/utils/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "scripts"],
  "exclude": ["node_modules", "dist"]
}
